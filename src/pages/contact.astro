---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Contact | AutoGo</title>
  </head>
  <body>
    <Navbar />
    
    <main class="contact-page">
       <div class="executive-section">
        <div class="executive-profile">
          <div class="profile-image">
            <img src="/logos/profile.png" alt="AutoGo" />
          </div>
          <div class="profile-info">
            <h2>Khaled</h2>
            <p class="title">Responsable des ventes</p>
            <p class="brand">AutoGo</p>
            <div class="locations">
              <p class="location">
                <svg class="location-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                Casablanca : 147, Bd Zerktouni étage5, bureau 12
              </p>
              <p class="location">
                <svg class="location-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                Rabat : Hay Riad
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="forms-section">
        <div class="form-card call-form">
          <h3>M'appeler</h3>
          <p class="form-subtitle">Demandez à être rappelé</p>
          <form>
            <div class="form-group">
              <input type="text" placeholder="Votre nom" required />
            </div>
            <div class="form-group">
              <input type="email" placeholder="Email" required />
            </div>
            <div class="form-group">
              <input type="tel" placeholder="Téléphone" required />
            </div>
            <div class="checkbox-group">
              <input type="checkbox" id="accept" />
              <label for="accept">J'accepte les conditions</label>
            </div>
            <button type="submit" class="submit-btn">
              M'appeler
              <span class="arrow-icon">↻</span>
            </button>
          </form>
        </div>

        <div class="form-card message-form">
          <h3>Envoyer un message</h3>
          <p class="form-subtitle">Écrivez-nous un message</p>
          <form>
            <div class="form-group">
              <input type="text" placeholder="Votre nom" required />
            </div>
            <div class="form-group">
              <input type="email" placeholder="Email" required />
            </div>
            <div class="form-group">
              <textarea placeholder="Message" required></textarea>
            </div>
            <button type="submit" class="submit-btn">
              Envoyer le message
              <span class="arrow-icon">→</span>
            </button>
          </form>
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Oswald', -apple-system, BlinkMacSystemFont, sans-serif;
    background-color: #f5f5f5;
    color: #000000;
    min-height: 100vh;
  }

  .contact-page {
    padding: 120px 48px 48px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .executive-section {
    text-align: center;
    margin-bottom: 64px;
  }

  .executive-profile {
    display: inline-block;
  }

  .profile-image {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    margin: 0 auto 24px;
    overflow: hidden;
    box-shadow: 0 0 0 4px #B6FF00;
  }

  .profile-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .profile-info h2 {
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .profile-info .title {
    font-size: 16px;
    opacity: 0.7;
    margin-bottom: 4px;
  }

  .profile-info .brand {
    font-size: 14px;
    color: #B6FF00;
    margin-bottom: 12px;
  }

  .profile-info .location {
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .location-icon {
    color: #B6FF00;
    display: inline-block;
    vertical-align: middle;
  }

  .forms-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    max-width: 900px;
    width: 100%;
  }

  .form-card {
    padding: 48px;
  }

  .call-form {
    background: #f5f5f5;
  }

  .message-form {
    background: #e5e5e5;
  }

  .form-card h3 {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .form-subtitle {
    font-size: 14px;
    opacity: 0.6;
    margin-bottom: 32px;
  }

  .form-group {
    margin-bottom: 24px;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 16px 0;
    background: transparent;
    border: none;
    border-bottom: 1px solid #B6FF00;
    color: #000000;
    font-size: 16px;
    font-family: inherit;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    background: rgba(182, 255, 0, 0.05);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: rgba(0, 0, 0, 0.4);
  }

  .form-group textarea {
    min-height: 100px;
    resize: vertical;
  }

  .checkbox-group {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .checkbox-group input[type="checkbox"] {
    width: 20px;
    height: 20px;
    border: 1px solid #B6FF00;
    accent-color: #B6FF00;
  }

  .checkbox-group label {
    font-size: 14px;
    opacity: 0.7;
  }

  .submit-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 32px;
    background: transparent;
    color: #000000;
    border: 1px solid #B6FF00;
    font-size: 16px;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .submit-btn:hover {
    background: #B6FF00;
    color: #000000;
  }

  .arrow-icon {
    color: #B6FF00;
  }

  .submit-btn:hover .arrow-icon {
    color: #000000;
  }

  @media (max-width: 768px) {
    .contact-page {
      padding: 100px 24px 32px;
    }

    .forms-section {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .form-card {
      padding: 32px;
    }
  }
</style>