---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>About | AutoGo</title>
  </head>
  <body>
    <Navbar />
    
    <main class="about-page">
      <div class="mission-section">
        <h1>About AutoGo</h1>
        <p>We are revolutionizing the future of sustainable mobility. Our premium electric vehicle rental service combines cutting-edge technology with exceptional customer experience. Every journey becomes an adventure, every ride becomes a statement.</p>
      </div>

      <div class="hero-section">
        <img src="/logos/logo.png" alt="AutoGo" class="hero-logo" />
        <div class="hero-glow"></div>
      </div>

      <div class="values-section">
        <h2>Our Values</h2>
        <div class="values-grid">
          <div class="value">
            <h3>Sustainability</h3>
            <p>Committed to zero-emission mobility for a cleaner future.</p>
          </div>
          <div class="value">
            <h3>Innovation</h3>
            <p>Leading the electric revolution with cutting-edge tech.</p>
          </div>
          <div class="value">
            <h3>Premium</h3>
            <p>Uncompromising quality in every detail.</p>
          </div>
          <div class="value">
            <h3>Customer First</h3>
            <p>Your journey is our priority.</p>
          </div>
        </div>
      </div>

<div class="story-section">
        <p>From daily rentals to long-term leases, we offer flexible solutions that fit your lifestyle. Every car in our fleet is selected for its exceptional quality, innovative features, and commitment to environmental responsibility.</p>
      </div>

      <div class="grid-section">
        <div class="grid-item">
          <h3>SUV</h3>
          <p>Premium electric SUV for every journey</p>
          <a href="/cars" class="learn-link">Learn more <span>→</span></a>
        </div>
        <div class="grid-item">
          <h3>Sedan</h3>
          <p>Elegant performance redefined</p>
          <a href="/cars" class="learn-link">Learn more <span>→</span></a>
        </div>
        <div class="grid-item">
          <h3>Family</h3>
          <p>Space meets sustainability</p>
          <a href="/cars" class="learn-link">Learn more <span>→</span></a>
        </div>
        <div class="grid-item">
          <h3>Compact</h3>
          <p>City driving perfected</p>
          <a href="/cars" class="learn-link">Learn more <span>→</span></a>
        </div>
      </div>

      <div class="purpose-section">
        <div class="purpose-content">
          <div class="purpose-hero">
            <img src="https://www.polestar.com/dato-assets/94392/1695801480-microsoftteams-image-63.png?fm=avif&only-imgix=true&fit=min&q=80&dpr=1&w=1920" alt="Innovation" />
          </div>
          <div class="purpose-text">
            <h2>The Purpose</h2>
            <p>Design as a tool for a cleaner future. We believe that every detail matters, from the materials we use to the technology that powers our vehicles. Innovation in powertrains is not just about efficiency — it's about redefining what's possible.</p>
            <p>Our commitment to sustainability drives us to constantly push boundaries, creating vehicles that don't compromise on performance while protecting our planet.</p>
          </div>
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Oswald', -apple-system, BlinkMacSystemFont, sans-serif;
    background-color: #f5f5f5;
    color: #000000;
    min-height: 100vh;
  }

  .about-page {
    padding-top: 120px;
  }

  .mission-section {
    padding: 64px 48px;
  }

  .mission-section h1 {
    font-size: 64px;
    font-weight: 700;
    margin-bottom: 32px;
  }

  .mission-section p {
    font-size: 24px;
    line-height: 1.6;
    max-width: 800px;
    margin-left: auto;
    opacity: 0.9;
  }

  .hero-section {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px;
    overflow: hidden;
  }

  .hero-logo {
    width: 80%;
    max-width: 800px;
    height: auto;
    opacity: 0.9;
    position: relative;
    z-index: 2;
  }

  .hero-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(182, 255, 0, 0.3) 0%, transparent 70%);
    filter: blur(60px);
    z-index: 1;
    animation: glow 4s ease-in-out infinite alternate;
  }

  @keyframes glow {
    0% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }
    100% { opacity: 0.8; transform: translate(-50%, -50%) scale(1.1); }
  }

  .values-section {
    padding: 80px 48px;
  }

  .values-section h2 {
    font-size: 48px;
    font-weight: 700;
    margin-bottom: 48px;
    text-align: center;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .value {
    text-align: center;
  }

  .value h3 {
    font-size: 24px;
    font-weight: 700;
    color: #B6FF00;
    margin-bottom: 16px;
  }

  .value p {
    font-size: 16px;
    opacity: 0.7;
    line-height: 1.5;
  }

  .story-section {
    padding: 80px 48px;
    max-width: 800px;
    margin: 0 auto;
  }

  .story-section h2 {
    font-size: 48px;
    font-weight: 700;
    margin-bottom: 32px;
    text-align: center;
  }

  .story-section p {
    font-size: 18px;
    line-height: 1.8;
    margin-bottom: 24px;
    opacity: 0.9;
  }

  .grid-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .grid-item {
    padding: 48px;
    border-right: 1px solid #B6FF00;
    border-bottom: 1px solid #B6FF00;
  }

  .grid-item:nth-child(2n) {
    border-right: none;
  }

  .grid-item:last-child {
    border-right: none;
  }

  .grid-item h3 {
    font-size: 36px;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .grid-item p {
    font-size: 16px;
    opacity: 0.7;
    margin-bottom: 24px;
  }

  .learn-link {
    color: #000000;
    text-decoration: none;
    font-size: 16px;
    font-weight: 500;
  }

  .learn-link span {
    color: #B6FF00;
  }

  .purpose-section {
    padding-top: 64px;
  }

  .purpose-content {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .purpose-hero {
    padding: 0;
  }

  .purpose-hero img {
    width: 100%;
    height: auto;
  }

  .purpose-text {
    padding: 0;
  }

  .purpose-text h2 {
    font-size: 56px;
    font-weight: 700;
    margin-bottom: 32px;
  }

  .purpose-text p {
    font-size: 18px;
    line-height: 1.8;
    opacity: 0.9;
    margin-bottom: 24px;
  }

  @media (max-width: 768px) {
    .mission-section {
      padding: 48px 24px;
    }

    .mission-section h1 {
      font-size: 40px;
    }

    .mission-section p {
      font-size: 18px;
      text-align: left;
    }

    .nav-section {
      flex-wrap: wrap;
      padding: 16px 24px;
    }

    .nav-links {
      display: none;
    }

    .hero-section {
      min-height: 40vh;
      padding: 48px 24px;
    }

    .hero-logo {
      width: 100%;
      max-width: 400px;
    }

    .hero-glow {
      width: 300px;
      height: 300px;
    }

    .values-section {
      padding: 48px 24px;
    }

    .values-section h2 {
      font-size: 32px;
    }

    .values-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .story-section {
      padding: 48px 24px;
    }

    .story-section h2 {
      font-size: 32px;
    }

    .story-section p {
      font-size: 16px;
    }

    .grid-section {
      grid-template-columns: 1fr;
    }

    .grid-item {
      padding: 32px 24px;
      border-right: none;
      border-bottom: 1px solid #B6FF00;
    }

    .grid-item:last-child {
      border-bottom: none;
    }

    .grid-item h3 {
      font-size: 28px;
    }

    .purpose-section {
      padding-top: 48px;
    }

    .purpose-content {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .purpose-hero {
      padding: 0 24px;
    }

    .purpose-text {
      padding: 24px;
    }

    .purpose-text h2 {
      font-size: 32px;
    }

    .purpose-text p {
      font-size: 16px;
    }
  }
</style>