  <script>
    // @ts-nocheck
    const vehicleSelect = document.getElementById('vehicleSelect');
  const pickupDate = document.getElementById('pickupDate');
  const dropoffDate = document.getElementById('dropoffDate');
  const locationInput = document.getElementById('locationInput');
  const phoneInput = document.getElementById('phoneInput');
  const bookBtn = document.getElementById('bookBtn');

  bookBtn?.addEventListener('click', () => {
    if (!vehicleSelect?.value) {
      alert('Veuillez sélectionner un véhicule');
      vehicleSelect?.focus();
      return;
    }
    if (!pickupDate?.value) {
      alert('Veuillez sélectionner une date de retrait');
      pickupDate?.focus();
      return;
    }
    if (!dropoffDate?.value) {
      alert('Veuillez sélectionner une date de retour');
      dropoffDate?.focus();
      return;
    }
    if (!locationInput?.value) {
      alert('Veuillez entrer un point de retrait');
      locationInput?.focus();
      return;
    }
    if (!phoneInput?.value) {
      alert('Veuillez entrer votre numéro de téléphone');
      phoneInput?.focus();
      return;
    }
    
    window.location.href = '/car/' + vehicleSelect.value + '?pickup=' + pickupDate.value + '&dropoff=' + dropoffDate.value + '&location=' + encodeURIComponent(locationInput.value) + '&phone=' + encodeURIComponent(phoneInput.value);
  });
</script>